WEBINTEL_ENVIRONMENT=development
WEBINTEL_LOG_LEVEL=INFO
WEBINTEL_DATABASE_URL=postgresql+asyncpg://webintel:webintel@localhost:5432/webintel
WEBINTEL_REDIS_URL=redis://localhost:6379/0
WEBINTEL_CRAWL_QUEUE_NAME=crawl_jobs
WEBINTEL_DATABASE_POOL_SIZE=5
WEBINTEL_READINESS_TIMEOUT_SECONDS=2
WEBINTEL_CRAWLER_USER_AGENT=WebIntelBot/0.1 (respectful website intelligence crawler)
WEBINTEL_FETCH_TIMEOUT_SECONDS=10
WEBINTEL_FETCH_RETRIES=2
WEBINTEL_FETCH_MAX_REDIRECTS=5
WEBINTEL_FETCH_MAX_RESPONSE_BYTES=5000000
WEBINTEL_API_PORT=8000

POSTGRES_DB=webintel
POSTGRES_USER=webintel
POSTGRES_PASSWORD=webintel
